# MCP / 写作工具 API 密钥（复制为 .env.mcp 后填入，勿提交）

# --- 网文 / 出版 ---
MEM0_API_KEY=
TAVILY_API_KEY=

# --- 图像 ---
RECRAFT_API_KEY=
IDEOGRAM_API_KEY=
ACEDATACLOUD_API_TOKEN=

# --- 世界观 / 资料 ---
WA_AUTH_TOKEN=
# NOTION: 推荐 OAuth，见 Cursor 连接 Notion MCP 时授权

# --- Obsidian（言情/古风）---
OBSIDIAN_VAULT_PATH=
# 默认使用 ${workspaceFolder}/vault

# --- Lex（悬疑/出版，可选初始化: npx @smartergpt/lex init）---
LEX_WORKSPACE_ROOT=

# --- 无 MCP、需手动配置 ---
# Novelcrafter: 本地 Codex 导出
# Sudowrite: 浏览器插件或 viaSocket
# Storybird: 网页端
# Acontext: Docker 自托管 https://github.com/memodb-io/Acontext
