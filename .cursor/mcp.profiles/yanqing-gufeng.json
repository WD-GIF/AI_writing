{
  "$comment": "言情/古风 | Sudowrite + Ideogram + Obsidian",
  "mcpServers": {
    "obsidian": {
      "command": "npx",
      "args": ["-y", "obsidian-mcp-server"],
      "env": {
        "OBSIDIAN_VAULT_PATH": "${workspaceFolder}/vault"
      }
    },
    "ideogram": {
      "command": "npx",
      "args": ["-y", "@qmediat.io/ideogram-mcp"],
      "env": {
        "IDEOGRAM_API_KEY": "${env:IDEOGRAM_API_KEY}"
      }
    }
  }
}
